# Database Configuration
# PostgreSQL connection string with format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://doutor_agenda:password@localhost:5432/doutor_agenda

# Google OAuth Configuration
# Create OAuth credentials at https://console.cloud.google.com
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Stripe Configuration
# Get keys from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLIC_KEY=pk_test_your_stripe_public_key

# Stripe Webhook Secret
# Set up webhook at https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Stripe Product/Plan Configuration
# Create product and price in Stripe dashboard, copy the price ID here
STRIPE_ESSENTIAL_PLAN_PRICE_ID=price_your_product_price_id

# Application URL (used for OAuth callbacks and redirects)
# For development: http://localhost:3000
# For production: https://your-domain.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Better Auth Secret (used for session encryption)
# Generate with: openssl rand -hex 32
BETTER_AUTH_SECRET=your_generated_secret_key_here_32_bytes_hex
